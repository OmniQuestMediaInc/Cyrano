{
  "name": "chatnowzone-build",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint 'services/**/*.ts' --max-warnings 0",
    "test": "jest --testPathPatterns='tests/integration' --passWithNoTests",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "typecheck:api": "tsc --noEmit --project services/core-api/tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --skip-generate",
    "seed:scheduling": "ts-node scripts/seed-scheduling.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": ".",
    "roots": [
      "<rootDir>/tests/integration"
    ],
    "testMatch": [
      "<rootDir>/tests/integration/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "commonjs",
          "target": "ES2021",
          "experimentalDecorators": true,
          "emitDecoratorMetadata": true,
          "esModuleInterop": true,
          "resolveJsonModule": true,
          "skipLibCheck": true,
          "strictNullChecks": true,
          "noImplicitAny": false
        }
      }
    }
  },
  "engines": {
    "node": ">=20 <23",
    "yarn": ">=1.22"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/typeorm": "^11.0.0",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "decimal.js": "10.6.0",
    "nats": "^2.29.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "jest": "^30.3.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.4.9",
    "typescript": "5.9.3"
  }
}
