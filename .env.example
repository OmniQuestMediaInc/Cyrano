# Cyrano™ — Environment Variable Template
# ============================================================================
# Copy to .env (or .env.local) and fill in real values. NEVER commit a populated
# .env file. Variables marked REQUIRED have no default — docker-compose will
# fail to start without them.
# ============================================================================

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000

# ── Database (Postgres) ─────────────────────────────────────────────────────
# REQUIRED. Used by docker-compose to bring up the db container and by Prisma.
POSTGRES_DB=cyrano
POSTGRES_USER=cyrano_app
DB_PASSWORD=

# DATABASE_URL is consumed by Prisma + NestJS. When running via docker-compose
# the api container builds it from POSTGRES_USER/DB_PASSWORD/POSTGRES_DB. For
# local `yarn prisma migrate dev` runs against a host port, set it explicitly.
DATABASE_URL=postgresql://cyrano_app:${DB_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ── Cache + queue (Redis) ───────────────────────────────────────────────────
# REQUIRED.
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ── Real-time fabric (NATS) ─────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Module feature flags (default ON in production) ─────────────────────────
LEDGER_ENABLED=true
GATEGUARD_ENABLED=true
RECOVERY_ENABLED=true
DIAMOND_CONCIERGE_ENABLED=true
FFS_ENABLED=true
CREATOR_CONTROL_ENABLED=true
CYRANO_ENABLED=true
INTEGRATION_HUB_ENABLED=true
AUDIT_IMMUTABLE_ENABLED=true
STREAMING_ENABLED=true

# ── Payments (Stripe) ───────────────────────────────────────────────────────
# REQUIRED for production. Use sk_test_* in dev/CI.
STRIPE_SECRET_KEY=
# Optional: enables the Stripe sandbox E2E smoke when set; CI skips when empty.
STRIPE_TEST_KEY=

# ── Voice cloning (ElevenLabs) ──────────────────────────────────────────────
# REQUIRED for voice-call feature.
ELEVENLABS_API_KEY=

# ── Image generation (Flux + Banana.dev) ────────────────────────────────────
# REQUIRED for AI Twin training + photorealistic image generation.
FLUX_API_KEY=
BANANA_API_KEY=
BANANA_API_ENDPOINT=
BANANA_MODEL_KEY_FLUX_PRO=

# ── AI Twin training tunables ───────────────────────────────────────────────
AI_TWIN_LORA_RANK=16

# ── Narrative engine ────────────────────────────────────────────────────────
NARRATIVE_MEMORY_TTL_DAYS=365

# ── Webhook + RBAC step-up signing ──────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=
RBAC_STEP_UP_SIGNING_SECRET=

# ── Cyrano standalone UI (Next.js, port 3100) ───────────────────────────────
CYRANO_CORE_API_URL=http://localhost:3000
NEXT_PUBLIC_CYRANO_API_URL=http://localhost:3000

# ── Brand portals (Next.js, ports 3001–3006) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
