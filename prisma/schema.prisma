  stream_key_hash String?  @unique @db.VarChar(64)
  // OBS-001: CREATOR_AUTO flag gates persona auto-responses. Default false.
  creator_auto    Boolean  @default(false)
  // RBAC-STUDIO-001: denormalised affiliation number for fast profile reads
  // and login/verification flows. Source-of-truth lives on the Studio row;
  // this column mirrors it after the StudioAffiliation is created. Permanent
  // once set — no regeneration policy is enforced at the application layer.
  affiliation_number String? @db.VarChar(9)
  organization_id String   @db.VarChar(100)
  tenant_id       String   @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz
