  /// Null = shared (applies to all games). Otherwise SPIN_WHEEL | SLOT_MACHINE | DICE.
  scoped_game_type  String?  @db.VarChar(20)
  version           String   @db.VarChar(50)
  rule_applied_id   String   @default("PRIZE_POOL_v1") @db.VarChar(100)
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz

  @@index([creator_id, is_active, scoped_game_type])
  @@map("prize_pools")
}

model PrizePoolEntry {
  entry_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pool_id         String   @db.Uuid
  prize_slot      String   @db.VarChar(40)
  name            String   @db.VarChar(120)
  description     String
  /// COMMON | RARE | EPIC | LEGENDARY
  rarity          String   @db.VarChar(20)
  base_weight     Decimal  @db.Decimal(10, 4)
  asset_url       String?  @db.VarChar(500)
  is_active       Boolean  @default(true)
  rule_applied_id String   @default("PRIZE_POOL_v1") @db.VarChar(100)
