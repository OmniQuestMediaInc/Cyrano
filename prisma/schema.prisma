  // WO-002: HCZ Zoey scheduler additions
  target_weekly_hours     Int       @default(385)         // Tenths of hours: 385 = 38.5h target
  min_weekly_hours        Int       @default(360)         // Tenths of hours: 360 = 36.0h floor
  jurisdiction            String    @default("ON")        // Provincial jurisdiction code
  birthday                DateTime? @db.Date
  sick_hours_remaining    Int       @default(40)          // Hours: 40h = 5 sick days
