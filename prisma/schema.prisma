// ─── CANONICAL FINANCIAL LEDGER — Payload 1 (OQMI_GOVERNANCE + REDBOOK) ──────
// New canonical three-bucket wallet layer sourced from services/ledger/.
// Prisma model names are prefixed `Canonical*` to coexist with the legacy
// LedgerEntry (payment-gateway oriented) without colliding. Table names follow
// the directive: wallets, wallet_ledger_entries, token_expirations, rate_cards.
// Append-only: wallet_ledger_entries never UPDATE or DELETE (hash-chained).

model CanonicalWallet {
  id               String   @id @default(cuid())
  user_id          String   @unique
  user_type        String   // "guest" | "creator" | "diamond"

  // Three-bucket balances — enforced by services/ledger/ (never write directly).
  purchased_tokens  Int     @default(0)
  membership_tokens Int     @default(0)
  bonus_tokens      Int     @default(0)

  last_updated     DateTime @updatedAt
  organization_id  String
  tenant_id        String
  created_at       DateTime @default(now())

  ledger_entries    CanonicalLedgerEntry[]
  token_expirations CanonicalTokenExpiration[]

  @@index([user_type])
  @@index([organization_id, tenant_id])
  @@map("wallets")
}

model CanonicalLedgerEntry {
  id              String   @id @default(cuid())
  wallet_id       String
  correlation_id  String   @unique
  reason_code     String   // "PURCHASE" | "SPEND" | "PAYOUT" | "EXPIRY_RECOVERY" | "TOKEN_BRIDGE" | "THREE_FIFTHS_EXIT" | ...
  amount          Int      // signed: positive = credit, negative = debit
  bucket          String   // "purchased" | "membership" | "bonus"
  token_type      String   @default("CZT") @db.VarChar(10) // CZT only — single-token economy enforced at DB level
  metadata        Json?
  hash_prev       String?
  hash_current    String
  created_at      DateTime @default(now())

  wallet          CanonicalWallet @relation(fields: [wallet_id], references: [id])

  @@index([wallet_id, correlation_id])
  @@index([wallet_id, created_at])
  @@index([reason_code])
  @@index([token_type])
  @@map("wallet_ledger_entries")
}

model CanonicalTokenExpiration {
  id           String    @id @default(cuid())
  wallet_id    String
  tokens       Int
  expires_at   DateTime
  status       String    // "active" | "expired" | "recovered" | "extended"
  recovery_fee Decimal?  @db.Decimal(10, 2)
  created_at   DateTime  @default(now())

  wallet       CanonicalWallet @relation(fields: [wallet_id], references: [id])

