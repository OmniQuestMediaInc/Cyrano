  token_tiers_csv            String   @db.VarChar(60)
  prize_pool_id              String   @db.Uuid
  cooldown_seconds_override  Int?
  enabled                    Boolean  @default(true)
  accepts_rrr_burn           Boolean  @default(false)
  version                    String   @db.VarChar(50)
  rule_applied_id            String   @default("CREATOR_GAME_CONFIG_v1") @db.VarChar(100)
  created_at                 DateTime @default(now()) @db.Timestamptz

  @@index([creator_id, game_type, enabled])
  @@map("creator_game_configs")
}

model GameCooldownLog {
  log_id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @db.Uuid
  creator_id       String   @db.Uuid
  game_type        String   @db.VarChar(20)
  played_at_utc    DateTime @db.Timestamptz
  next_play_at_utc DateTime @db.Timestamptz
  rule_applied_id  String   @default("GAMIFICATION_COOLDOWN_v1") @db.VarChar(100)
  created_at       DateTime @default(now()) @db.Timestamptz

  @@index([user_id, creator_id, game_type, next_play_at_utc])
  @@map("game_cooldown_logs")
}

model RedRoomRewardsBurn {
  burn_id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String   @db.Uuid
  creator_id             String   @db.Uuid
  game_type              String   @db.VarChar(20)
  rrr_points_burned      Int
  czt_tokens_equivalent  Int
  correlation_id         String   @unique @db.VarChar(200)
  reason_code            String   @default("GAME_PLAY") @db.VarChar(40)
  rule_applied_id        String   @default("RRR_BURN_v1") @db.VarChar(100)
  burned_at_utc          DateTime @default(now()) @db.Timestamptz

  @@index([user_id, burned_at_utc])
  @@map("redroom_rewards_burns")
}

// ─── Diamond Concierge Sessions — K) Wave K ───────────────────────────────────
// Append-only session records for VIP Diamond / Inferno-tier concierge requests.
// Status lifecycle: pending → in_progress → completed | cancelled.
// All writes go through DiamondConciergeSessionService (core-api).

model ConciergeSession {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.VarChar(200)
  request        String   @db.Text
  /// "pending" | "in_progress" | "completed" | "cancelled"
  status         String   @default("pending") @db.VarChar(20)
  /// "high" | "normal"
  priority       String   @default("high") @db.VarChar(20)
  correlation_id String   @unique @db.VarChar(200)
  reason_code    String   @default("CONCIERGE_REQUEST") @db.VarChar(60)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  @@index([user_id, status, created_at])
  @@map("concierge_sessions")
}

// ─── User RRR Points Ledger — L) Wave L ──────────────────────────────────────
// Append-only points ledger for guest/user-facing RedRoom Rewards points.
// Positive entries = awards; negative entries = burns.
// Balance = SUM(amount) for a given user_id.
// OQMI invariant: no UPDATE on balance columns — offsets only.

model UserRrPointsLedger {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.VarChar(200)
  /// Signed integer: positive = award, negative = burn
  amount         Int
  /// DAILY_LOGIN | MESSAGE_SENT | IMAGE_GENERATED | VOICE_CALL | REFERRAL |
  ///   HOUSE_MODEL_CHAT | PORTAL_SWITCH | BURN_EXTRA_IMAGES | BURN_TEMP_INFERNO |
  ///   BURN_CUSTOM_TWIN
  action         String   @db.VarChar(40)
  description    String   @db.VarChar(200)
  correlation_id String   @unique @db.VarChar(200)
  reason_code    String   @default("RRR_AWARD") @db.VarChar(40)
  created_at     DateTime @default(now()) @db.Timestamptz

  @@index([user_id, created_at])
  @@index([user_id, action, created_at])
  @@map("user_rrr_points_ledger")
}

// ─── Burn Reward Grants — L) Wave L ──────────────────────────────────────────
// Records grants issued when a user burns RRR points for a reward.
// The downstream effect (extra images, temp tier, custom twin) is applied by
// the service consuming this record; this table is the authoritative source of
// truth for what was promised.

model BurnRewardGrant {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @db.VarChar(200)
  points_burned     Int
  /// "EXTRA_IMAGES" | "TEMP_INFERNO" | "CUSTOM_TWIN"
  reward_type       String    @db.VarChar(30)
  expires_at        DateTime? @db.Timestamptz
  fulfilled_at      DateTime? @db.Timestamptz
  correlation_id    String    @unique @db.VarChar(200)
  reason_code       String    @default("RRR_BURN_REWARD") @db.VarChar(40)
  created_at        DateTime  @default(now()) @db.Timestamptz

  @@index([user_id, reward_type, created_at])
  @@map("burn_reward_grants")
}

// ─── Cyrano Standalone — AI Twin, Image Generation, Voice Cloning, Narrative Engine ─────────
// CYR: These models power the AI companion / character product layer.
//      All tables include correlation_id + reason_code per §5.2 schema discipline.

// ── AI Twin ──────────────────────────────────────────────────────────────────

model AiTwin {
  twin_id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id        String         @db.Uuid
  display_name      String         @db.VarChar(120)
  persona_prompt    String         @db.Text
  trigger_word      String         @db.VarChar(80)
  /// "PRIVATE" | "PLATFORM_INTERNAL" | "SUBSCRIBER"
  visibility        String         @default("PRIVATE") @db.VarChar(20)
  /// true = house model (platform-owned, 100% revenue to platform)
  is_house_model    Boolean        @default(false)
  /// true = free Spark Twin provisioned on signup (limited to 15 messages/day)
  is_spark_twin     Boolean        @default(false)
  /// Portal brand this twin belongs to: MAIN | INK_AND_STEEL | LOTUS_BLOOM | DESPERATE_HOUSEWIVES | BARELY_LEGAL | DARK_DESIRES
  portal            String?        @db.VarChar(30)
  /// "PENDING_UPLOAD" | "UPLOAD_COMPLETE" | "TRAINING_QUEUED" | "TRAINING_IN_PROGRESS" | "TRAINING_COMPLETE" | "TRAINING_FAILED" | "RETIRED"
  training_status   String         @default("PENDING_UPLOAD") @db.VarChar(30)
  lora_weights_url  String?        @db.Text
  training_error    String?        @db.Text
  trained_at        DateTime?      @db.Timestamptz
  correlation_id    String         @unique @db.VarChar(200)
  reason_code       String         @default("TWIN_CREATE") @db.VarChar(40)
  created_at        DateTime       @default(now()) @db.Timestamptz
  updated_at        DateTime       @updatedAt @db.Timestamptz

  photos            AiTwinPhoto[]
  voice_clones      VoiceClone[]
  image_caches      ImageCache[]
  memory_banks      MemoryBank[]
  narrative_branches NarrativeBranch[]

  @@index([creator_id, training_status])
  @@index([is_house_model, training_status])
  @@index([creator_id, is_spark_twin])
  @@map("ai_twins")
}

model AiTwinPhoto {
  photo_id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  twin_id        String   @db.Uuid
  storage_key    String   @db.Text
  correlation_id String   @unique @db.VarChar(200)
  reason_code    String   @default("PHOTO_UPLOAD") @db.VarChar(40)
  created_at     DateTime @default(now()) @db.Timestamptz

  twin           AiTwin   @relation(fields: [twin_id], references: [twin_id])

  @@index([twin_id])
  @@map("ai_twin_photos")
}

// ── Image Generation / Cache ──────────────────────────────────────────────────

model ImageCache {
  image_cache_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  twin_id        String   @db.Uuid
  creator_id     String   @db.Uuid
  user_id        String   @db.Uuid
  prompt_hash    String   @db.VarChar(64)
  prompt_used    String   @db.Text
  /// "flux-pro" | "flux-schnell" | "flux-dev"
  model          String   @db.VarChar(30)
  storage_url    String   @db.Text
  width          Int
  height         Int
  correlation_id String   @unique @db.VarChar(200)
  reason_code    String   @default("IMAGE_GEN") @db.VarChar(40)
  generated_at   DateTime @default(now()) @db.Timestamptz

  twin           AiTwin   @relation(fields: [twin_id], references: [twin_id])

  @@index([twin_id, prompt_hash, generated_at])
  @@index([user_id, generated_at])
  @@map("image_caches")
}

// ── Voice Cloning ─────────────────────────────────────────────────────────────

model VoiceClone {
  voice_clone_id       String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  twin_id              String              @db.Uuid
  creator_id           String              @db.Uuid
  voice_name           String              @db.VarChar(120)
  description          String?             @db.Text
  labels_json          String?             @db.Text
  elevenlabs_voice_id  String?             @db.VarChar(100)
  /// "PENDING_SAMPLES" | "SAMPLES_READY" | "CLONING_IN_PROGRESS" | "CLONE_COMPLETE" | "CLONE_FAILED" | "RETIRED"
  status               String              @default("PENDING_SAMPLES") @db.VarChar(30)
  clone_error          String?             @db.Text
  cloned_at            DateTime?           @db.Timestamptz
  correlation_id       String              @unique @db.VarChar(200)
  reason_code          String              @default("VOICE_CLONE_CREATE") @db.VarChar(40)
  created_at           DateTime            @default(now()) @db.Timestamptz
  updated_at           DateTime            @updatedAt @db.Timestamptz

  twin                 AiTwin              @relation(fields: [twin_id], references: [twin_id])
  samples              VoiceCloneSample[]

  @@index([twin_id, status])
  @@map("voice_clones")
}

model VoiceCloneSample {
  sample_id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voice_clone_id   String     @db.Uuid
  storage_key      String     @db.Text
  duration_seconds Float
  correlation_id   String     @unique @db.VarChar(200)
  reason_code      String     @default("VOICE_SAMPLE_UPLOAD") @db.VarChar(40)
  created_at       DateTime   @default(now()) @db.Timestamptz

  voice_clone      VoiceClone @relation(fields: [voice_clone_id], references: [voice_clone_id])

  @@index([voice_clone_id])
  @@map("voice_clone_samples")
}

// ── Narrative Engine — Persistent Memory Bank ─────────────────────────────────

model MemoryBank {
  memory_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id       String   @db.VarChar(200)
  twin_id          String   @db.Uuid
  user_id          String   @db.Uuid
  /// "FACT" | "PREFERENCE" | "EMOTION" | "STORY_BEAT" | "RELATIONSHIP" | "SECRET"
  memory_type      String   @db.VarChar(20)
  content          String   @db.Text
  /// 0.0–1.0; higher = recalled first in context window
  importance_score Float    @default(0.5)
  expires_at       DateTime? @db.Timestamptz
  correlation_id   String   @unique @db.VarChar(200)
  reason_code      String   @default("MEMORY_STORE") @db.VarChar(40)
  created_at       DateTime @default(now()) @db.Timestamptz

  twin             AiTwin   @relation(fields: [twin_id], references: [twin_id])

  @@index([twin_id, user_id, importance_score(sort: Desc)])
  @@index([twin_id, user_id, expires_at])
  @@map("memory_banks")
}

// ── Narrative Engine — Cinematic Branching ────────────────────────────────────

model NarrativeBranch {
  branch_id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  twin_id            String    @db.Uuid
  user_id            String    @db.Uuid
  branch_title       String    @db.VarChar(200)
  branch_premise     String    @db.Text
  decision_prompt    String    @db.Text
  options_json       String    @db.Text
  resolved           Boolean   @default(false)
  chosen_option_key  String?   @db.VarChar(10)
  resolved_at        DateTime? @db.Timestamptz
  correlation_id     String    @unique @db.VarChar(200)
  reason_code        String    @default("BRANCH_CREATE") @db.VarChar(40)
  created_at         DateTime  @default(now()) @db.Timestamptz

  twin               AiTwin    @relation(fields: [twin_id], references: [twin_id])

  @@index([twin_id, user_id, resolved])
  @@map("narrative_branches")
}

// ─── Promotion Engine — PROMO-001 ────────────────────────────────────────────

model PromoCode {
  id               String    @id @default(uuid())
  code             String    @unique @db.VarChar(50)
  discount_percent Int
  expires_at       DateTime  @db.Timestamptz
  max_uses         Int
  used_count       Int       @default(0)
  correlation_id   String    @unique @db.VarChar(200)
  reason_code      String    @default("PROMO_CREATED") @db.VarChar(50)
  created_at       DateTime  @default(now()) @db.Timestamptz
  updated_at       DateTime  @updatedAt @db.Timestamptz

  @@map("promo_codes")
}

// ─── Benefits Usage — BENEFITS-001 ───────────────────────────────────────────

model BenefitUsage {
  id             String   @id @default(uuid())
  user_id        String   @db.Uuid
  month          String   @db.VarChar(7)   // YYYY-MM
  images_used    Int      @default(0)
  voice_minutes  Int      @default(0)
  correlation_id String   @db.VarChar(200)
  reason_code    String   @default("BENEFIT_USAGE_INIT") @db.VarChar(50)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  @@unique([user_id, month], name: "userId_month")
  @@index([user_id, month])
  @@map("benefit_usage")
// ── Spark Twin — Free Tier Daily Usage Tracking ───────────────────────────────
// Tracks per-user daily message count for the free Spark Twin tier.
// Free users are capped at 15 messages per calendar day (usage_date = YYYY-MM-DD).
// Increment is applied via upsert; no UPDATE on a balance column — compliant with
// APPEND-ONLY FINANCE invariant (this is a counter, not a ledger balance).

model SparkTwinDailyUsage {
  usage_id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  /// Calendar date of usage: YYYY-MM-DD (UTC)
  usage_date     String   @db.VarChar(10)
  messages_sent  Int      @default(0)
  correlation_id String   @unique @db.VarChar(200)
  reason_code    String   @default("SPARK_DAILY_USAGE") @db.VarChar(40)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  @@unique([user_id, usage_date])
  @@index([user_id, usage_date])
  @@map("spark_twin_daily_usages")
}
