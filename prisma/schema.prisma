// ─── RBAC-STUDIO-001: Studio Onboarding + Affiliation + RBAC ────────────
// Spec: services/studio-affiliation + services/creator-onboarding +
//       services/affiliation-number generator. Append-only writes carry
//       correlation_id + reason_code + rule_applied_id (Canonical L0).

enum StudioStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

enum StudioRole {
  STUDIO_OWNER
  STUDIO_ADMIN
  CREATOR
}

enum AffiliationStatus {
  ACTIVE
  PENDING
  REVOKED
}

enum OnboardingStatus {
  PENDING
  AFFILIATED
  COMPLETE
}

enum StudioContractStatus {
  UPLOADED
  SIGNED
  COUNTERSIGNED
  VOIDED
}

model Studio {
  id                  String       @id @default(uuid())
  name                String       @db.VarChar(200)
  // 6-9 char uppercase alphanumeric (A-Z, 2-9 — excludes 0, 1, O, I).
  // Length range enforced by the AffiliationNumberService + DB CHECK.
  // Uniqueness enforced globally (no organization scope).
  affiliation_number  String       @unique @db.VarChar(9)
  status              StudioStatus @default(PENDING)
  // Commission set by PLATFORM_ADMIN only (read-only on the studio dashboard).
  // Stored as a 4-decimal fraction (e.g. 0.2500 == 25%). Bounded 0..1.
  commission_rate     Decimal      @default(0.0000) @db.Decimal(5, 4)
  // Multi-tenant scoping (every write must include).
  organization_id     String       @db.VarChar(100)
  tenant_id           String       @db.VarChar(100)
  // Canonical audit columns — populated on every mutation by the service layer.
  correlation_id      String       @db.VarChar(128)
  reason_code         String       @db.VarChar(64)
  rule_applied_id     String       @db.VarChar(100)
  created_at          DateTime     @default(now()) @db.Timestamptz
  updated_at          DateTime     @updatedAt @db.Timestamptz

  affiliations        StudioAffiliation[]
  contracts           StudioContractDocument[]
  onboardings         CreatorOnboarding[]

  @@index([affiliation_number])
  @@index([status, organization_id])
  @@map("studios")
}

model StudioAffiliation {
  id              String            @id @default(uuid())
  studio_id       String
  creator_id      String
  role            StudioRole        @default(CREATOR)
  status          AffiliationStatus @default(ACTIVE)
  joined_at       DateTime          @default(now()) @db.Timestamptz
  // Canonical audit columns.
  correlation_id  String            @db.VarChar(128)
  reason_code     String            @db.VarChar(64)
  rule_applied_id String            @db.VarChar(100)
  organization_id String            @db.VarChar(100)
  tenant_id       String            @db.VarChar(100)
  created_at      DateTime          @default(now()) @db.Timestamptz
  updated_at      DateTime          @updatedAt @db.Timestamptz

  studio          Studio            @relation(fields: [studio_id], references: [id])
  creator         Creator           @relation(fields: [creator_id], references: [id])

  @@unique([studio_id, creator_id])
  @@index([creator_id])
  @@index([status, role])
  @@map("studio_affiliations")
}

model CreatorOnboarding {
  id                  String           @id @default(uuid())
  creator_id          String           @unique
  // Resolved studio (NULL until affiliation is granted).
  studio_id           String?
  // Mirror of studio.affiliation_number for read-side convenience.
  affiliation_number  String?          @db.VarChar(9)
  status              OnboardingStatus @default(PENDING)
  // Secondary email used for the verification code step.
  secondary_email     String?          @db.VarChar(255)
  email_verified_at   DateTime?        @db.Timestamptz
  // Optional studio-domain block reason (audit only).
  email_block_reason  String?          @db.VarChar(64)
  // Canonical audit columns.
  correlation_id      String           @db.VarChar(128)
  reason_code         String           @db.VarChar(64)
  rule_applied_id     String           @db.VarChar(100)
  organization_id     String           @db.VarChar(100)
  tenant_id           String           @db.VarChar(100)
  created_at          DateTime         @default(now()) @db.Timestamptz
  updated_at          DateTime         @updatedAt @db.Timestamptz

  creator             Creator          @relation(fields: [creator_id], references: [id])
  studio              Studio?          @relation(fields: [studio_id], references: [id])

  @@index([affiliation_number])
  @@index([status])
  @@map("creator_onboardings")
}

model StudioContractDocument {
  id                  String               @id @default(uuid())
  studio_id           String
  // FK to Creator (the signing party). Studio side is the studio owner.
  creator_id          String
  // Storage URI for the uploaded document (e.g. s3://… or assets-service ref).
  storage_uri         String               @db.VarChar(500)
  // SHA-256 of the document bytes — used to detect tampering at sign time.
  document_hash       String               @db.Char(64)
  status              StudioContractStatus @default(UPLOADED)
  // Typed-name signature block (MVP). Prod: replace with cryptographic.
  signed_typed_name   String?              @db.VarChar(200)
  signed_at           DateTime?            @db.Timestamptz
  // Canonical audit columns.
  correlation_id      String               @db.VarChar(128)
  reason_code         String               @db.VarChar(64)
  rule_applied_id     String               @db.VarChar(100)
  organization_id     String               @db.VarChar(100)
  tenant_id           String               @db.VarChar(100)
  created_at          DateTime             @default(now()) @db.Timestamptz
  updated_at          DateTime             @updatedAt @db.Timestamptz

  studio              Studio               @relation(fields: [studio_id], references: [id])

  @@index([studio_id, status])
  @@index([creator_id])
  @@map("studio_contract_documents")
}

// ─── GateGuard Sentinel Pre-Processor (Business Plan B.5 + Canonical Corpus) ─
// Every financial transaction (purchase / spend / payout) is routed through
// GateGuard BEFORE it reaches the append-only ledger. Each evaluation yields
// a Welfare Guardian Score (fraud + welfare + risk factors) that drives a
// deterministic decision: APPROVE / COOLDOWN / HARD_DECLINE / HUMAN_ESCALATE.
//
// Both tables are append-only. The GateGuardLog is hash-chained so that any
// tampering with a decision record is detectable downstream (Audit Chain).

model WelfareGuardianScore {
  id              String   @id @default(uuid())
  // A single transaction receives exactly one authoritative score.
  transaction_id  String   @unique @db.VarChar(200)
  // Both scores are normalised integers in the 0..100 band.
  fraud_score     Int
  welfare_score   Int
  // Aggregate risk: opaque JSON envelope produced by the scorer. Shape is
  // intentionally flexible — new signals can be added without migration.
  risk_factors    Json
  // Final gate decision. Mirrors GateGuardDecision in the service layer.
  decision        String   @db.VarChar(32)
  // Correlation across microservices (ledger, NATS, UI) for a single attempt.
  correlation_id  String   @db.VarChar(100)
  // Rule set version used to produce this score — never mutated after write.
  rule_applied_id String   @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([correlation_id])
  @@index([decision, created_at])
  @@map("welfare_guardian_scores")
}

model GateGuardLog {
  id              String   @id @default(uuid())
  transaction_id  String   @db.VarChar(200)
  // Action being gated: "PURCHASE" | "SPEND" | "PAYOUT" | "AV_CALLBACK" ...
  action          String   @db.VarChar(50)
  // Snapshot of the score object at decision time.
  score           Json
  decision        String   @db.VarChar(32)
  // Hash chain — hash_current = SHA256(hash_prior || canonical(payload))
  hash_prior      String   @db.Char(64)
  hash_current    String   @db.Char(64)
  correlation_id  String   @db.VarChar(100)
  rule_applied_id String   @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([transaction_id])
  @@index([correlation_id])
  @@index([action, created_at])
  @@map("gateguard_logs")
}

// ── PAYLOAD 6: Immutable Audit Architecture ──────────────────────────────
// Canonical Corpus v10, Chapter 7 §5 + Appendix D/H.
// Append-only. Hash-chained. No UPDATE, no DELETE. Enforced at the service
// layer (ImmutableAuditService) and, in production, by DB triggers.
// Every row: hash_current = SHA-256(hash_prior || canonical(payload_hash)).
// payload_hash itself is a SHA-256 of the redacted, canonicalised payload
// so raw sensitive data never enters the ledger.

model ImmutableAuditEvent {
  event_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type      String   @db.VarChar(64)
  // Correlation across spans of the same business flow (purchase, recovery,
  // gateguard decision, cyrano suggestion, etc.). Unique to prevent double
  // emission for the same business event.
  correlation_id  String   @unique @db.VarChar(128)
  actor_id        String   @db.VarChar(128)
  actor_role      String   @db.VarChar(32)
  reason_code     String   @db.VarChar(64)
  // SHA-256 of canonical(redacted_payload). Never store raw PII or secrets.
  payload_hash    String   @db.Char(64)
  // Hash chain pointers — hash_prior is nullable ONLY for genesis row.
  hash_prior      String?  @db.Char(64)
  hash_current    String   @db.Char(64)
  // Monotonic sequence number within the chain for O(1) prior lookup.
  sequence_number BigInt   @unique
  // Non-sensitive metadata (ids, codes, outcomes). Never raw payload fields.
  metadata        Json?
  rule_applied_id String   @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([event_type, created_at])
  @@index([actor_id, event_type])
  @@map("immutable_audit_events")
}

// Periodic WORM (Write-Once-Read-Many) export seals. Each row pins a
// contiguous range of immutable_audit_events via first/last sequence numbers
// and a hash_seal covering the ordered event IDs + timestamps. A failing
// verify_integrity call is a P0 incident.
model WormExportRecord {
  export_id          String   @id @db.VarChar(128)
  from_utc           DateTime @db.Timestamptz
  to_utc             DateTime @db.Timestamptz
  first_event_id     String   @db.Uuid
  last_event_id      String   @db.Uuid
  first_sequence     BigInt
  last_sequence      BigInt
  event_count        Int
  hash_seal          String   @db.Char(64)
  storage_uri        String?  @db.VarChar(512)
  integrity_verified Boolean  @default(true)
  rule_applied_id    String   @db.VarChar(100)
  exported_at        DateTime @default(now()) @db.Timestamptz

  @@index([exported_at])
  @@map("worm_export_records")
}

