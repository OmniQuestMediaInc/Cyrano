// ─── Flicker n'Flame Scoring (FFS) ──────────────────────────────────────────
// Replaces Room-Heat Engine (services/room-heat/ → services/ffs/).
// Rule authority: FFS_ENGINE_v1

/// Time-series FFS score snapshots — one row per ingest() call.
/// Append-only by convention (no UPDATE/DELETE in service code).
model FfsSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id      String   @db.VarChar(200)
  creator_id      String   @db.Uuid
  ffs_score       Decimal  @db.Decimal(5, 2)
  ffs_tier        String   @db.VarChar(20)
  /// JSON object of FfsScoreComponents (all 13 component values).
  components      Json
  correlation_id  String   @db.VarChar(128)
  reason_code     String   @db.VarChar(100)
  is_dual_flame   Boolean  @default(false)
  rule_applied_id String   @default("FFS_ENGINE_v1") @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([session_id, created_at])
  @@index([creator_id, created_at])
  @@map("ffs_snapshots")
}

/// Per-creator adaptive weight multipliers, learned from tip events.
/// One row per creator — updated in-place via increment-only tip_events_seen.
model FfsAdaptiveWeights {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id      String   @unique @db.Uuid
  /// JSON Record<string, number> — multipliers for each FFS component.
  weights         Json
  /// Monotonic counter of tip events that have driven weight updates.
  tip_events_seen Int      @default(0)
  last_updated_at DateTime @default(now()) @db.Timestamptz
  correlation_id  String   @db.VarChar(128)
  reason_code     String   @default("FFS_ADAPTIVE_INIT") @db.VarChar(100)
  rule_applied_id String   @default("FFS_ENGINE_v1") @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz

  @@map("ffs_adaptive_weights")
}

// ── SenSync™ Biometric Layer (HZ — SenSync consent store) ────────────────────
// Law 25 / GDPR / PIPEDA compliant. consent_granted_at is immutable once
// recorded. Revocation is tracked by setting consent_revoked_at on the
// existing consent row; the service does not create a separate revocation row.
// The correlation_id column is overwritten with the revocation action's ID
// for a complete audit trail.
// Automatic purge on deletion request fires SENSYNC_PURGE_REQUESTED on NATS.
// Rule authority: SENSYNC_v1

/// Per-tier on/off toggle for SenSync™ biometric relay.
/// Managed by platform operators. Non-FIZ; no financial impact.
model SenSyncTierConfig {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Membership tier this row governs.
  tier           String   @db.VarChar(40)
  /// Whether SenSync™ relay is enabled for this tier.
  enabled        Boolean  @default(false)
  /// Whether COMBINED ("feel as one") mode is permitted for this tier.
  combined_mode  Boolean  @default(false)
  correlation_id String   @db.VarChar(100)
  reason_code    String   @db.VarChar(100)
  updated_by     String   @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz

  @@unique([tier])
  @@index([tier, enabled])
  @@map("sensync_tier_configs")
}

model SenSyncConsent {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id              String    @db.Uuid
  creator_id              String    @db.Uuid
  guest_id                String    @db.Uuid
  consent_version         String    @db.VarChar(20)          // e.g. "SENSYNC_CONSENT_v1"
  basis                   String    @db.VarChar(50)          // EXPLICIT_OPT_IN | REVOKED
  consent_granted_at      DateTime  @db.Timestamptz
  consent_revoked_at      DateTime? @db.Timestamptz          // null until revoked
  /// Phase 5.3 — granular consent scopes (JSON string array).
  /// Default: ['BPM_TO_FFS','BPM_TO_HAPTIC','BPM_TO_CYRANO','BPM_TO_PARTNER']
  /// Single scopes can be revoked without revoking the entire consent row.
  consent_scopes          Json      @default("[\"BPM_TO_FFS\",\"BPM_TO_HAPTIC\",\"BPM_TO_CYRANO\",\"BPM_TO_PARTNER\"]")
  /// Phase 5.3 — ephemerality TTL. NULL means no auto-expiry.
  /// Default lifetime is 24h from grant; the rate-limit / submit gate refuses
  /// samples once the row has expired and the purge worker tombstones the row.
  consent_expires_at      DateTime? @db.Timestamptz
  ip_hash                 String?   @db.Char(64)             // SHA-256 of guest IP — never raw
  device_fingerprint      String?   @db.VarChar(255)
  domain                  String    @default("ADULT_ENTERTAINMENT") @db.VarChar(50)
  correlation_id          String    @db.VarChar(200)
  reason_code             String    @db.VarChar(100)
  rule_applied_id         String    @default("SENSYNC_v1") @db.VarChar(100)
  purge_requested_at      DateTime? @db.Timestamptz          // Law 25 deletion request
  purge_completed_at      DateTime? @db.Timestamptz
  created_at              DateTime  @default(now()) @db.Timestamptz

  @@index([session_id])
  @@index([creator_id, guest_id])
  @@index([guest_id, consent_revoked_at])
  @@index([consent_expires_at])
  @@map("sensync_consents")
}

// ── Cyrano™ Persistent Session Memory ────────────────────────────────────────
// Restart-safe memory store backing the in-memory SessionMemoryStore.
// Rows are scaffolded for future persistence; upserted on fact/arc writes.
// Soft-delete on guest purge.

model CyranoSessionMemory {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id        String    @db.Uuid
  guest_id          String    @db.Uuid
  memory_type       String    @db.VarChar(10)        // FACT | ARC
  memory_key        String    @db.VarChar(200)       // fact.key or arc_id
  memory_value      Json                             // MemoryFact | SessionArc payload
  confidence        Decimal?  @db.Decimal(4, 3)      // 0.000–1.000 (facts only)
  last_touched_at   DateTime  @db.Timestamptz
  is_purged         Boolean   @default(false)
  correlation_id    String    @db.VarChar(200)
  reason_code       String    @db.VarChar(100)
  rule_applied_id   String    @default("CYRANO_MEMORY_v1") @db.VarChar(100)
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  @@unique([creator_id, guest_id, memory_type, memory_key])
  @@index([creator_id, guest_id])
  @@map("cyrano_session_memory")
}

// ─── VelocityZone — Creator Payout Rate Engine ───────────────────────────────
// Business Plan §3 — time-window payout rate events keyed to FFS score.
// Rule authority: VELOCITYZONE_v1

/// Per-creator payout rate tier audit trail.
/// FIZ-scoped: any mutation requires REASON/IMPACT/CORRELATION_ID in commit.
model CreatorRateTier {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tier_id          String   @unique @db.Uuid
  creator_id       String   @db.Uuid
  /// Tier name: 'FOUNDING' | 'STANDARD' | 'POST_DAY_61'
  tier_name        String   @db.VarChar(30)
  /// Minimum payout rate (USD per CZT).
  rate_floor_usd   Decimal  @db.Decimal(8, 6)
  /// Maximum payout rate (USD per CZT).
  rate_ceiling_usd Decimal  @db.Decimal(8, 6)
  effective_from   DateTime @db.Timestamptz
  effective_to     DateTime? @db.Timestamptz
  correlation_id   String   @db.VarChar(128)
  reason_code      String   @db.VarChar(100)
  rule_applied_id  String   @default("VELOCITYZONE_v1") @db.VarChar(100)
  created_at       DateTime @default(now()) @db.Timestamptz

  @@index([creator_id, effective_from])
  @@index([tier_name])
  @@map("creator_rate_tiers")
}

/// Admin-defined time-window VelocityZone event.
/// Maps FFS score (0–100) to exact payout rate (floor → ceiling) during the window.
model VelocityZoneEvent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id         String   @unique @db.Uuid
  name             String   @db.VarChar(100)
  starts_at        DateTime @db.Timestamptz
  ends_at          DateTime @db.Timestamptz
  rate_floor_usd   Decimal  @db.Decimal(8, 6)
  rate_ceiling_usd Decimal  @db.Decimal(8, 6)
  /// Empty = applies to all creators; non-empty = restricted to listed creator_ids.
  creator_ids      String[]
  /// 'SCHEDULED' | 'ACTIVE' | 'ENDED' | 'CANCELLED'
  status           String   @default("SCHEDULED") @db.VarChar(20)
  created_by       String   @db.Uuid
  correlation_id   String   @db.VarChar(128)
  reason_code      String   @db.VarChar(100)
  rule_applied_id  String   @default("VELOCITYZONE_v1") @db.VarChar(100)
  created_at       DateTime @default(now()) @db.Timestamptz

  @@index([status, starts_at, ends_at])
  @@map("velocityzone_events")
}

// ── Gamification (Phase G1) ─────────────────────────────────────────────────
// Append-only storage for creator prize pools, per-game config, cooldown logs,
// and RRR-burn payments. Edits produce a new row with a bumped `version`.

model PrizePool {
