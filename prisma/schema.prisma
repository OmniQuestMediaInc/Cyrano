  @@map("prize_pool_entries")
}

model CreatorGameConfig {
  config_id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id                 String   @db.Uuid
  game_type                  String   @db.VarChar(20)
