model StaffMember {
  id                      String    @id @default(uuid())
  employee_ref            String    @unique @db.VarChar(50)
  display_name            String    @db.VarChar(100)
  role                    String    @db.VarChar(20)       // GZM, GZAM, GZS, GZSA
  employment_type         String    @db.VarChar(10)       // FT, PT
  staff_category          String    @db.VarChar(10)       // CORE, EDGE
  department              String    @db.VarChar(30)       // GUESTZONE, FINANCE, TECH, LEGAL, MAINTENANCE, RECEPTION
  languages               String[]                        // e.g. ['EN','FR','ES']
  hourly_rate_cad         Decimal?  @db.Decimal(8, 2)    // Hourly staff
